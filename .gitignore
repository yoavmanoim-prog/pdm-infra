# Local .terraform directories
**/.terraform/*

# State files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files with secrets (keep terraform.tfvars in version control
# only if it contains no secrets — move secrets to a separate *.auto.tfvars)
*.auto.tfvars
*.auto.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*.tfplan

# CLI config
.terraformrc
terraform.rc

# Lock file — commit this to pin provider versions
# .terraform.lock.hcl
